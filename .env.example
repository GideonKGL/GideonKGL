NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/safety_backend?schema=public

JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m

CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20

# Optional Firebase Admin credentials.
# Provide either FIREBASE_SERVICE_ACCOUNT_BASE64, FIREBASE_SERVICE_ACCOUNT_JSON, or
# GOOGLE_APPLICATION_CREDENTIALS for application default credentials.
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_SERVICE_ACCOUNT_JSON=

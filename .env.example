NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:5173
DESKTOP_ORIGIN=http://localhost:5174
DATABASE_URL=postgresql://guardian:guardian_password@localhost:5432/guardian_tracker?schema=public
JWT_ACCESS_SECRET=replace-with-64-byte-access-secret
JWT_REFRESH_SECRET=replace-with-64-byte-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_COMPATIBILITY=false
FIREBASE_PROJECT_ID=replace-with-project-id
FIREBASE_CLIENT_EMAIL=replace-with-service-account-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace\n-----END PRIVATE KEY-----\n"
GOOGLE_MAPS_WEB_API_KEY=replace-with-web-key
GOOGLE_MAPS_ANDROID_API_KEY=replace-with-android-key
VITE_API_BASE_URL=http://localhost:4000/api/v1
VITE_SOCKET_URL=http://localhost:4000
VITE_GOOGLE_MAPS_API_KEY=replace-with-web-key

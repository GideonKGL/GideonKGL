{
  "name": "windows-desktop-monitoring-console",
  "version": "1.0.0",
  "description": "Windows desktop monitoring console for real-time GPS, SOS, incidents, evidence, history, and reporting.",
  "author": "Cursor Cloud Agent",
  "license": "MIT",
  "private": true,
  "type": "commonjs",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dev:electron": "npm run build:electron && concurrently -k \"npm:dev\" \"npm:watch:electron\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "watch:electron": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.electron.json",
    "package": "npm run build && electron-builder --win --x64",
    "package:dir": "npm run build && electron-builder --dir",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "socket.io-client": "^4.8.3"
  },
  "build": {
    "appId": "com.monitoring.console",
    "productName": "Monitoring Console",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  }
}
